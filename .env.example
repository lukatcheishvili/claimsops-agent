# Vertex AI / CrewAI live mode
# The Vercel app requests Vertex AI by default. Set VERTEX_AI_LIVE=false only for deterministic-only demos.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=agenticai-500006
GOOGLE_CLOUD_PROJECT_NUMBER=***
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_AI_LIVE=true
VERTEX_AI_MODEL=gemini-2.0-flash
CREWAI_MODEL=gemini/gemini-2.0-flash
CREWAI_STORAGE_DIR=claimsops-agent
CREWAI_DISABLE_TELEMETRY=true
CREWAI_DISABLE_TRACKING=true

# Vercel / Next.js Vertex AI route.
# Add this in Vercel Project Settings -> Environment Variables.
# Use a service account with permission to call Vertex AI. Never commit the real value.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"agenticai-500006","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...@agenticai-500006.iam.gserviceaccount.com","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}

# Keep false for class demos unless credentials and connectivity are verified.
USE_CREWAI_LIVE=false
